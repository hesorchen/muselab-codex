# muselab-codex deployment configuration.
# Copy to .env, keep it private, and never commit real values.

# Required application configuration.
MUSELAB_TOKEN=change-me-to-a-random-token-with-at-least-16-characters
MUSELAB_ROOT=/absolute/path/to/your/workspace
MUSELAB_PORT=8765
MUSELAB_HOST=127.0.0.1

# Optional Web Push VAPID subject. Must use a mailto: URI.
# MUSELAB_VAPID_SUBJECT=mailto:noreply@example.com

# Optional: select a non-default Codex executable.
# CODEX_BIN=codex

# muselab supervises a Unix-socket app-server listener in a private runtime
# directory outside MUSELAB_ROOT. Override that location when needed:
# MUSELAB_RUNTIME_DIR=/private/path/to/muselab-codex-runtime
# To open the same live runtime from a terminal, copy the command shown in
# Settings → About (codex resume --remote unix:///.../app-server.sock).

# Optional Codex-native Responses providers. After setting a key, restart the
# service and enable its provider in Settings → Model providers. Codex owns
# provider configuration under $CODEX_HOME; key values stay in this private
# service environment and never pass through the browser settings API.
MINIMAX_API_KEY=
DASHSCOPE_API_KEY=
XIAOMI_MIMO_API_KEY=
